# ═══════════════════════════════════════════════════════════════════
#  Tweet QA Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────

# DeepSeek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# PostgreSQL connection string with pgvector
#
# Local (Unix socket — peer auth, no password needed):
DATABASE_URL=postgresql:///tweets_rag
#
# Local with Docker (pgvector/pg16 container):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tweets
#
# Remote (Supabase / cloud):
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:6543/postgres?sslmode=require

# ── Embeddings (FastEmbed — runs on CPU, no API key needed) ───────

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Stable name stored in the DB — keeps existing embeddings queryable
# after changing the underlying model library:
# DB_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LangSmith (optional — for tracing & debugging) ────────────────

# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=tweet-qa-agent
